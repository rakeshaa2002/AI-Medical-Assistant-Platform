# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=medassist
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
# Optionally provide a single URL (overrides the above if set)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/medassist

# CORS / Frontend
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT lifetimes (minutes / days)
ACCESS_TOKEN_LIFETIME_MIN=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# OCR (path to the tesseract binary if not on PATH; Windows example below)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Email (notifications). Console backend used automatically when DEBUG=True.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=MedAssist <no-reply@medassist.local>
